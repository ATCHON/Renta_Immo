# URL complète du webhook n8n pour le calcul de rentabilité
# Format: https://votre-instance-n8n.com/webhook/votre-chemin
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL= # Direct connection string (postgresql://...)

# Better Auth configuration
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3001

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
RESEND_API_KEY=
EMAIL_SENDER="Renta Immo <onboarding@resend.dev>"

# Sentry Error Tracking (ARCH-S02) — Datacenter EU obligatoire (RGPD)
# DSN format EU : https://<key>@o<org>.ingest.de.sentry.io/<project>
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENABLED=true   # Mettre false pour désactiver Sentry (maîtrise des coûts)

# Upstash Redis (ARCH-S01 rate limiting distribué + ARCH-S03 cache ConfigService)
# Créer une base Redis sur https://console.upstash.com — récupérer REST URL et token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ConfigService cache TTL (ARCH-S03) — défaut: 300s (5 min)
CONFIG_CACHE_TTL_SECONDS=300
